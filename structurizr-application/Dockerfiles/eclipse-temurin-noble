FROM eclipse-temurin:21.0.11_10-jre-noble

ENV PORT=8080

COPY structurizr-application/target/structurizr-*.war /usr/local/structurizr.war
COPY structurizr-themes /usr/local/structurizr-themes
COPY structurizr-application/Dockerfiles/structurizr.sh /usr/local/structurizr.sh
RUN chmod +x /usr/local/structurizr.sh

EXPOSE ${PORT}

WORKDIR /usr/local/structurizr

ENTRYPOINT ["/usr/local/structurizr.sh"]